{
  "name": "bloomswiftpos",
  "version": "1.0.0",
  "description": "BloomSwiftPOS - Point of Sale System",
  "main": "electron/main.js",
  "author": {
    "name": "BloomSwiftPOS",
    "email": "support@bloomswiftpos.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "start": "electron .",
    "dev": "concurrently \"npm run start:frontend\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:start": "electron .",
    "start:backend": "cd backend && node -r ts-node/register/transpile-only index.ts",
    "start:frontend": "cd frontend && npm run dev",
    "electron:dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:all && electron-builder --linux",
    "electron:build:deb": "npm run build:all && electron-builder --linux deb",
    "electron:build:appimage": "npm run build:all && electron-builder --linux AppImage",
    "electron:dist": "npm run build:all && electron-builder --linux deb AppImage",
    "build:all": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npx tsc",
    "build:frontend": "cd frontend && npm run build && mkdir -p ../frontend-build && cp -r dist/* ../frontend-build/",
    "backend:dev": "cd backend && npm start",
    "frontend:dev": "cd frontend && npm run dev"
  },
  "dependencies": {
    "canvas": "^3.2.0",
    "dotenv": "^17.2.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "jsbarcode": "^3.12.1",
    "pg": "^8.16.3",
    "puppeteer": "^22.0.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bloomswift.pos",
    "productName": "BloomSwiftPOS",
    "copyright": "Copyright © 2024-2026 BloomSwiftPOS",
    "files": [
      "electron/**/*",
      "electron/diagnostic.html",
      "electron/logger.js",
      "frontend-build/**/*",
      "backend/dist/**/*",
      "backend/src/**/*",
      "backend/node_modules/**/*",
      "backend/package.json",
      "Assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/src",
        "to": "backend/src",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "icon": "Assets/BLOOM_SWIFT_POS_LOGO_XS_T.png",
      "synopsis": "Point of Sale System",
      "description": "A comprehensive Point of Sale system for retail management with inventory, sales, and reporting features.",
      "desktop": {
        "Name": "BloomSwiftPOS",
        "Comment": "Point of Sale System",
        "GenericName": "POS System",
        "Categories": "Office;Finance;",
        "Keywords": "pos;sales;inventory;retail;",
        "Terminal": false,
        "StartupWMClass": "BloomSwiftPOS"
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0"
      ],
      "afterInstall": "install/post-install.sh"
    },
    "appImage": {}
  }
}
